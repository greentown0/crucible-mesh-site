<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — Crucible Mesh</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── Variables ─────────────────────────────────────────── */
    :root {
      --bg:          #FFFFFF;
      --bg-1:        #F7F8FA;
      --bg-2:        #EEF1F5;
      --bg-3:        #E4E8EF;
      --accent:      #004ECC;
      --accent-dim:  rgba(0, 78, 204, 0.35);
      --accent-glow: rgba(0, 78, 204, 0.06);
      --warn:        #B45309;
      --text:        #374151;
      --text-hi:     #0F172A;
      --text-lo:     #94A3B8;
      --mono:        'Fira Code', 'Courier New', monospace;
      --sans:        'Libre Franklin', system-ui, sans-serif;
      --cond:        'Libre Franklin', system-ui, sans-serif;
      --border:      #E2E8F0;
      --border-hi:   #CBD5E1;
      --border-accent: rgba(0, 78, 204, 0.20);
    }

    /* ── Reset ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    /* ── Base ──────────────────────────────────────────────── */
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-weight: 400;
      font-size: 16px;
      line-height: 1.75;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Header ────────────────────────────────────────────── */
    header {
      position: relative;
      z-index: 10;
      border-bottom: 1px solid var(--border);
      padding: 0 clamp(20px, 5vw, 80px);
      background: var(--bg);
    }

    /* Precision top rule */
    header::before {
      content: '';
      display: block;
      height: 3px;
      background: var(--accent);
    }

    .header-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 40px 0 36px;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 28px;
    }

    .mesh-icon {
      width: 44px;
      height: 44px;
      flex-shrink: 0;
      opacity: 0.85;
    }

    .site-name {
      font-family: var(--sans);
      font-size: clamp(1.2rem, 3vw, 1.75rem);
      font-weight: 700;
      color: var(--text-hi);
      letter-spacing: 0.08em;
      line-height: 1.1;
      text-transform: uppercase;
    }
    .site-name em {
      font-style: normal;
      color: var(--accent);
    }
    .site-tagline {
      font-family: var(--sans);
      font-size: 0.78rem;
      font-weight: 300;
      color: var(--text-lo);
      margin-top: 6px;
      letter-spacing: 0.02em;
    }

    .freq-badge {
      text-align: right;
      flex-shrink: 0;
      padding-left: 28px;
      border-left: 1px solid var(--border);
    }
    .freq-value {
      font-family: var(--mono);
      font-size: clamp(1rem, 2.2vw, 1.5rem);
      font-weight: 500;
      color: var(--accent);
      display: block;
      letter-spacing: 0.02em;
    }
    .freq-label {
      font-family: var(--sans);
      font-size: 0.68rem;
      font-weight: 400;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--text-lo);
      display: block;
      margin-top: 4px;
    }
    .status-dot {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 8px;
      font-family: var(--sans);
      font-size: 0.66rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #16A34A;
    }
    .status-dot::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #16A34A;
      animation: pulse-dot 2.5s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    /* ── Main content ──────────────────────────────────────── */
    main {
      position: relative;
      z-index: 1;
      max-width: 960px;
      margin: 0 auto;
      padding: 56px clamp(20px, 5vw, 80px) 96px;
      counter-reset: section;
    }

    /* ── Section headings ───────────────────────────────────── */
    main h2 {
      font-family: var(--sans);
      font-size: 0.70rem;
      font-weight: 600;
      letter-spacing: 0.20em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 64px 0 22px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    main h2::before {
      counter-increment: section;
      content: '[' counter(section, decimal-leading-zero) ']';
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 400;
      color: var(--text-lo);
      letter-spacing: 0.06em;
    }
    main h2::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── Paragraphs ─────────────────────────────────────────── */
    main p {
      color: var(--text);
      margin-bottom: 18px;
      max-width: 70ch;
      font-weight: 400;
    }
    main p strong {
      color: var(--text-hi);
      font-weight: 600;
    }

    /* ── Tables ─────────────────────────────────────────────── */
    main table {
      width: 100%;
      border-collapse: collapse;
      margin: 24px 0;
      font-family: var(--mono);
      font-size: 0.875rem;
      position: relative;
    }
    main table::before { display: none; }

    main thead th {
      padding: 9px 16px;
      text-align: left;
      font-family: var(--sans);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-lo);
      background: var(--bg-1);
      border-bottom: 2px solid var(--border-hi);
    }
    main tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.1s;
    }
    main tbody tr:hover {
      background: var(--bg-1);
    }
    main tbody tr:last-child { border-bottom: none; }
    main td {
      padding: 11px 16px;
      vertical-align: middle;
    }
    main td:first-child {
      color: var(--text-lo);
      width: 220px;
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      font-family: var(--sans);
    }
    main td:last-child {
      color: var(--text-hi);
      font-size: 0.90rem;
      font-weight: 500;
    }

    /* ── Code blocks ─────────────────────────────────────────── */
    main pre {
      margin: 24px 0;
      position: relative;
    }
    main pre::before {
      content: '// terminal';
      display: block;
      font-family: var(--sans);
      font-size: 0.60rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-lo);
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-bottom: none;
      padding: 6px 14px;
    }
    main pre code {
      display: block;
      font-family: var(--mono);
      font-size: 0.875rem;
      line-height: 1.85;
      color: var(--text-hi);
      background: var(--bg-1);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      padding: 18px 22px;
      overflow-x: auto;
    }
    main pre code::after {
      content: '█';
      color: var(--accent);
      animation: blink 1.2s step-start infinite;
      margin-left: 2px;
      font-size: 0.8em;
      opacity: 0.4;
    }
    @keyframes blink {
      0%, 100% { opacity: 0.4; }
      50%       { opacity: 0; }
    }

    /* links */
    main a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid var(--border-accent);
      transition: border-color 0.12s;
    }
    main a:hover {
      border-bottom-color: var(--accent);
    }

    /* inline code */
    main p code, main li code {
      font-family: var(--mono);
      font-size: 0.85em;
      color: var(--accent);
      background: var(--accent-glow);
      padding: 1px 5px;
      border: 1px solid var(--border-accent);
    }

    /* ── Blockquote ──────────────────────────────────────────── */
    main blockquote {
      margin: 24px 0;
      padding: 16px 20px;
      background: #FFFBEB;
      border-left: 3px solid var(--warn);
    }
    main blockquote p {
      color: #92400E;
      margin-bottom: 0;
      font-size: 0.90rem;
    }
    main blockquote p::before {
      content: '⚠ ';
      color: var(--warn);
      font-weight: 600;
    }

    /* ── Lists ──────────────────────────────────────────────── */
    main ul, main ol {
      list-style: none;
      margin: 16px 0 20px;
      padding: 0;
    }
    main li {
      padding: 3px 0 3px 20px;
      position: relative;
      font-size: 0.95rem;
    }
    main li::before {
      content: '›';
      position: absolute;
      left: 4px;
      color: var(--accent);
      font-family: var(--sans);
      font-weight: 300;
    }

    /* ── Nav ────────────────────────────────────────────────── */
    nav {
      border-bottom: 1px solid var(--border);
      background: var(--bg-1);
      padding: 0 clamp(20px, 5vw, 80px);
    }
    .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      gap: 0;
    }
    nav a {
      display: inline-block;
      font-family: var(--sans);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-lo);
      text-decoration: none;
      border-bottom: none;
      padding: 12px 18px 12px 0;
      margin-right: 24px;
      border-bottom: 2px solid transparent;
      transition: color 0.12s, border-color 0.12s;
    }
    nav a:hover,
    nav a.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    /* ── Footer ──────────────────────────────────────────────── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 24px clamp(20px, 5vw, 80px);
      background: var(--bg-1);
    }
    .footer-inner {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    footer p {
      font-family: var(--sans);
      font-size: 0.70rem;
      font-weight: 400;
      color: var(--text-lo);
      letter-spacing: 0.06em;
    }
    footer p span { color: var(--accent); }

    /* ── Responsive ─────────────────────────────────────────── */
    @media (max-width: 640px) {
      .header-inner {
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
      }
      .freq-badge {
        grid-column: 1 / -1;
        text-align: left;
        border-left: none;
        border-top: 1px solid var(--border);
        padding-left: 0;
        padding-top: 14px;
      }
      main td:first-child { width: auto; }
      main table, main thead, main tbody, main th, main td, main tr { display: block; }
      main thead { display: none; }
      main tr { border-bottom: 1px solid var(--border); padding: 12px 0; }
      main tr:last-child { border-bottom: none; }
      main td { padding: 4px 16px; border: none; }
      main td:first-child {
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
        padding-top: 10px;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="header-inner">

      <!-- Mesh SVG icon -->
      <svg class="mesh-icon" viewBox="0 0 58 58" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="29" cy="6"  r="3.5" fill="#004ECC" opacity="0.9"/>
        <circle cx="50" cy="18" r="3.5" fill="#004ECC" opacity="0.9"/>
        <circle cx="50" cy="40" r="3.5" fill="#004ECC" opacity="0.9"/>
        <circle cx="29" cy="52" r="3.5" fill="#004ECC" opacity="0.9"/>
        <circle cx="8"  cy="40" r="3.5" fill="#004ECC" opacity="0.9"/>
        <circle cx="8"  cy="18" r="3.5" fill="#004ECC" opacity="0.9"/>
        <circle cx="29" cy="29" r="4.5" fill="#004ECC"/>
        <circle cx="29" cy="29" r="7"   fill="#004ECC" opacity="0.12"/>
        <line x1="29" y1="29" x2="29" y2="6"  stroke="#004ECC" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="50" y2="18" stroke="#004ECC" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="50" y2="40" stroke="#004ECC" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="29" y2="52" stroke="#004ECC" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="8"  y2="40" stroke="#004ECC" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="8"  y2="18" stroke="#004ECC" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="6"  x2="50" y2="18" stroke="#CBD5E1" stroke-width="0.8" opacity="0.8"/>
        <line x1="50" y1="18" x2="50" y2="40" stroke="#CBD5E1" stroke-width="0.8" opacity="0.8"/>
        <line x1="50" y1="40" x2="29" y2="52" stroke="#CBD5E1" stroke-width="0.8" opacity="0.8"/>
        <line x1="29" y1="52" x2="8"  y2="40" stroke="#CBD5E1" stroke-width="0.8" opacity="0.8"/>
        <line x1="8"  y1="40" x2="8"  y2="18" stroke="#CBD5E1" stroke-width="0.8" opacity="0.8"/>
        <line x1="8"  y1="18" x2="29" y2="6"  stroke="#CBD5E1" stroke-width="0.8" opacity="0.8"/>
      </svg>

      <div class="header-text">
        <div class="site-name">CRUCIBLE <em>MESH</em></div>
        <div class="site-tagline">Experimental LoRa Mesh Network · Configuration Reference</div>
      </div>

      <div class="freq-badge">
        <span class="freq-value">869.431</span>
        <span class="freq-label">MHz · EU ISM</span>
        <div class="status-dot">Active</div>
      </div>

    </div>
  </header>

  <nav>
    <div class="nav-inner">
      <a href="/" {% if page.url == "/" %}class="active"{% endif %}>Network Config</a>
      <a href="/useful-information/" {% if page.url == "/useful-information/" %}class="active"{% endif %}>Useful Information</a>
    </div>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <div class="footer-inner">
      <p>CRUCIBLE MESH · <span>Experimental</span> · Not for production use</p>
      <p>869.431 MHz · SF6 · BW 62.5 kHz · CR5</p>
    </div>
  </footer>

</body>
</html>
