<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — Crucible Mesh</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;500&family=Barlow+Condensed:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* ── Variables ─────────────────────────────────────────── */
    :root {
      --bg:          #05080e;
      --bg-1:        #090d15;
      --bg-2:        #0d1420;
      --bg-3:        #111b2b;
      --accent:      #00e5ff;
      --accent-dim:  rgba(0, 229, 255, 0.55);
      --accent-glow: rgba(0, 229, 255, 0.12);
      --warn:        #ff6b35;
      --text:        #c8dff2;
      --text-hi:     #f0f8ff;
      --text-lo:     #7a9ab5;
      --mono:        'Share Tech Mono', 'Courier New', monospace;
      --sans:        'Barlow', system-ui, sans-serif;
      --cond:        'Barlow Condensed', system-ui, sans-serif;
      --border:      rgba(0, 229, 255, 0.10);
      --border-hi:   rgba(0, 229, 255, 0.25);
    }

    /* ── Reset ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    /* ── Base ──────────────────────────────────────────────── */
    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-weight: 400;
      font-size: 18px;
      line-height: 1.75;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Background layers ─────────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,229,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,255,0.025) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }
    /* scanlines */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.18) 2px,
        rgba(0,0,0,0.18) 4px
      );
      pointer-events: none;
      z-index: 0;
    }

    /* ── Header ────────────────────────────────────────────── */
    header {
      position: relative;
      z-index: 10;
      border-bottom: 1px solid var(--border-hi);
      background: linear-gradient(180deg, rgba(0,229,255,0.04) 0%, transparent 100%);
      padding: 0 clamp(20px, 5vw, 80px);
    }

    /* top accent bar */
    header::before {
      content: '';
      display: block;
      height: 2px;
      background: linear-gradient(90deg, transparent 0%, var(--accent) 40%, var(--accent-dim) 70%, transparent 100%);
    }

    .header-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 52px 0 44px;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 32px;
    }

    /* mesh SVG icon */
    .mesh-icon {
      width: 58px;
      height: 58px;
      flex-shrink: 0;
      animation: icon-glow 4s ease-in-out infinite;
      filter: drop-shadow(0 0 6px rgba(0,229,255,0.35));
    }
    @keyframes icon-glow {
      0%,100% { filter: drop-shadow(0 0 5px rgba(0,229,255,0.35)); }
      50%      { filter: drop-shadow(0 0 14px rgba(0,229,255,0.65)); }
    }

    .header-text {}
    .site-name {
      font-family: var(--mono);
      font-size: clamp(1.6rem, 4vw, 2.8rem);
      color: var(--text-hi);
      letter-spacing: 0.04em;
      line-height: 1.1;
    }
    .site-name em {
      font-style: normal;
      color: var(--accent);
    }
    .site-tagline {
      font-family: var(--cond);
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-lo);
      margin-top: 8px;
    }

    /* frequency badge */
    .freq-badge {
      text-align: right;
      flex-shrink: 0;
    }
    .freq-value {
      font-family: var(--mono);
      font-size: clamp(1.1rem, 2.5vw, 1.7rem);
      color: var(--accent);
      display: block;
      letter-spacing: 0.03em;
    }
    .freq-label {
      font-family: var(--cond);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-lo);
      display: block;
      margin-top: 4px;
    }
    .status-dot {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 10px;
      font-family: var(--cond);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-lo);
    }
    .status-dot::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: blink 2.2s ease-in-out infinite;
      box-shadow: 0 0 4px var(--accent);
    }
    @keyframes blink {
      0%,100% { opacity: 1; }
      50%      { opacity: 0.15; }
    }

    /* ── Main content ──────────────────────────────────────── */
    main {
      position: relative;
      z-index: 1;
      max-width: 960px;
      margin: 0 auto;
      padding: 64px clamp(20px, 5vw, 80px) 96px;
    }

    /* ── Section headings (h2 from markdown) ───────────────── */
    main h2 {
      font-family: var(--mono);
      font-size: 1.15rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 72px 0 28px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    main h2::before {
      counter-increment: section;
      content: '[' counter(section, decimal-leading-zero) ']';
      opacity: 0.45;
    }
    main h2::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    main { counter-reset: section; }

    /* ── Paragraphs ────────────────────────────────────────── */
    main p {
      color: var(--text);
      margin-bottom: 18px;
      max-width: 70ch;
    }
    main p strong {
      color: var(--text-hi);
      font-weight: 500;
    }

    /* ── Tables ────────────────────────────────────────────── */
    main table {
      width: 100%;
      border-collapse: collapse;
      margin: 28px 0;
      font-family: var(--mono);
      font-size: 0.92rem;
      position: relative;
    }
    /* corner brackets via pseudo on a wrapper — handled with outline trick */
    main table::before {
      content: '';
      position: absolute;
      inset: -1px;
      border: 1px solid var(--border);
      pointer-events: none;
    }

    main thead th {
      padding: 10px 20px;
      text-align: left;
      font-family: var(--cond);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text);
      background: var(--bg-2);
      border-bottom: 1px solid var(--border-hi);
    }
    main tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }
    main tbody tr:hover {
      background: var(--accent-glow);
    }
    main tbody tr:last-child { border-bottom: none; }
    main td {
      padding: 12px 20px;
      vertical-align: middle;
    }
    main td:first-child {
      color: var(--text);
      width: 220px;
      font-size: 0.82rem;
      letter-spacing: 0.04em;
    }
    main td:last-child {
      color: var(--text-hi);
      font-size: 1rem;
    }

    /* ── Code blocks ───────────────────────────────────────── */
    main pre {
      margin: 28px 0;
      position: relative;
    }
    main pre::before {
      content: '// terminal';
      display: block;
      font-family: var(--cond);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-lo);
      background: var(--bg-3);
      border: 1px solid var(--border);
      border-bottom: none;
      padding: 7px 16px;
    }
    main pre code {
      display: block;
      font-family: var(--mono);
      font-size: 0.95rem;
      line-height: 1.8;
      color: #7effd4; /* phosphor green-cyan */
      background: var(--bg-1);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      padding: 20px 24px;
      overflow-x: auto;
    }
    /* blinking cursor at end of last line */
    main pre code::after {
      content: '█';
      color: var(--accent);
      animation: blink 1.1s step-start infinite;
      margin-left: 2px;
      font-size: 0.8em;
      opacity: 0.7;
    }

    /* links */
    main a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid var(--border-hi);
      transition: border-color 0.15s, color 0.15s;
    }
    main a:hover {
      color: var(--text-hi);
      border-bottom-color: var(--accent);
    }

    /* inline code */
    main p code, main li code {
      font-family: var(--mono);
      font-size: 0.85em;
      color: var(--accent);
      background: var(--accent-glow);
      padding: 1px 6px;
      border: 1px solid var(--border);
    }

    /* ── Blockquote (used for callouts) ────────────────────── */
    main blockquote {
      margin: 28px 0;
      padding: 18px 22px;
      background: rgba(255, 107, 53, 0.06);
      border-left: 3px solid var(--warn);
      border-top: 1px solid rgba(255,107,53,0.15);
      border-bottom: 1px solid rgba(255,107,53,0.15);
    }
    main blockquote p {
      color: #e0a888;
      margin-bottom: 0;
      font-size: 0.92rem;
    }
    main blockquote p::before {
      content: '⚠ ';
      color: var(--warn);
      font-weight: 500;
    }

    /* ── Lists ─────────────────────────────────────────────── */
    main ul, main ol {
      list-style: none;
      margin: 16px 0 20px;
      padding: 0;
    }
    main li {
      padding: 4px 0 4px 22px;
      position: relative;
      font-size: 0.95rem;
    }
    main li::before {
      content: '›';
      position: absolute;
      left: 4px;
      color: var(--accent);
      font-family: var(--mono);
    }

    /* ── Footer ────────────────────────────────────────────── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 28px clamp(20px, 5vw, 80px);
    }
    .footer-inner {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    footer p {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--text-lo);
      letter-spacing: 0.08em;
    }
    footer p span { color: var(--accent); opacity: 0.6; }

    /* ── Responsive ────────────────────────────────────────── */
    @media (max-width: 640px) {
      .header-inner {
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
      }
      .freq-badge { grid-column: 1 / -1; text-align: left; }

      main td:first-child { width: auto; }

      /* stack table on mobile */
      main table, main thead, main tbody, main th, main td, main tr { display: block; }
      main thead { display: none; }
      main tr { border-bottom: 1px solid var(--border); padding: 12px 0; }
      main tr:last-child { border-bottom: none; }
      main td { padding: 4px 16px; border: none; }
      main td:first-child {
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        padding-top: 10px;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="header-inner">

      <!-- Mesh SVG icon -->
      <svg class="mesh-icon" viewBox="0 0 58 58" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- outer ring nodes -->
        <circle cx="29" cy="6"  r="3.5" fill="#00e5ff" opacity="0.9"/>
        <circle cx="50" cy="18" r="3.5" fill="#00e5ff" opacity="0.9"/>
        <circle cx="50" cy="40" r="3.5" fill="#00e5ff" opacity="0.9"/>
        <circle cx="29" cy="52" r="3.5" fill="#00e5ff" opacity="0.9"/>
        <circle cx="8"  cy="40" r="3.5" fill="#00e5ff" opacity="0.9"/>
        <circle cx="8"  cy="18" r="3.5" fill="#00e5ff" opacity="0.9"/>
        <!-- center node -->
        <circle cx="29" cy="29" r="4.5" fill="#00e5ff"/>
        <circle cx="29" cy="29" r="7"   fill="#00e5ff" opacity="0.15"/>
        <!-- spokes center → outer -->
        <line x1="29" y1="29" x2="29" y2="6"  stroke="#00e5ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="50" y2="18" stroke="#00e5ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="50" y2="40" stroke="#00e5ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="29" y2="52" stroke="#00e5ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="8"  y2="40" stroke="#00e5ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="29" y1="29" x2="8"  y2="18" stroke="#00e5ff" stroke-width="1.2" opacity="0.5"/>
        <!-- outer ring -->
        <line x1="29" y1="6"  x2="50" y2="18" stroke="#00e5ff" stroke-width="0.8" opacity="0.25"/>
        <line x1="50" y1="18" x2="50" y2="40" stroke="#00e5ff" stroke-width="0.8" opacity="0.25"/>
        <line x1="50" y1="40" x2="29" y2="52" stroke="#00e5ff" stroke-width="0.8" opacity="0.25"/>
        <line x1="29" y1="52" x2="8"  y2="40" stroke="#00e5ff" stroke-width="0.8" opacity="0.25"/>
        <line x1="8"  y1="40" x2="8"  y2="18" stroke="#00e5ff" stroke-width="0.8" opacity="0.25"/>
        <line x1="8"  y1="18" x2="29" y2="6"  stroke="#00e5ff" stroke-width="0.8" opacity="0.25"/>
      </svg>

      <div class="header-text">
        <div class="site-name">CRUCIBLE <em>MESH</em></div>
        <div class="site-tagline">Experimental LoRa Mesh Network · Configuration Reference</div>
      </div>

      <div class="freq-badge">
        <span class="freq-value">869.431</span>
        <span class="freq-label">MHz · EU ISM</span>
        <div class="status-dot">Active</div>
      </div>

    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <div class="footer-inner">
      <p>CRUCIBLE MESH · <span>Experimental</span> · Not for production use</p>
      <p>869.431 MHz · SF6 · BW 62.5 kHz · CR5</p>
    </div>
  </footer>

</body>
</html>
